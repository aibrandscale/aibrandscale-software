// Prisma schema for AI BrandScale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum GenerationType {
  ANGLE
  STATIC
  VIDEO_SCRIPT
  ADVERTORIAL
}

enum GenerationStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum Plan {
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum UsageEventKind {
  GENERATION_CHARGE
  GENERATION_REFUND
  CYCLE_REFILL
  TRIAL_GRANT
  ADMIN_ADJUSTMENT
}

// ─── Auth (NextAuth / Auth.js v5) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  memberships       WorkspaceMember[]
  invitesSent       Invite[]              @relation("InvitesSent")
  generations       Generation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tenancy ────────────────────────────────────────────────────

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  currency     String   @default("USD") // ISO 4217, applied to product prices
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members       WorkspaceMember[]
  invites       Invite[]
  brands        Brand[]
  generations   Generation[]
  subscription  Subscription?
  usageEvents   UsageEvent[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Invite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        Role      @default(MEMBER)
  tokenHash   String    @unique // SHA-256 of the raw token
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InvitesSent", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([email])
}

// ─── Brand & product ────────────────────────────────────────────

model Brand {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  logoKey         String?
  website         String?
  languages       String[] // e.g. ["English", "Bulgarian"]
  primaryColor    String   @default("#7c3aed")
  secondaryColor  String   @default("#0a0812")
  accentColor     String   @default("#a78bfa")
  description     String   @db.Text
  features        String[] // bullet points
  targetAudience  String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  products    Product[]
  generations Generation[]

  @@index([workspaceId])
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String   @db.Text
  imageKeys   String[]
  features    String[]
  priceCents  Int? // optional, currency lives on Workspace
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([brandId])
}

// ─── Generations (polymorphic) ──────────────────────────────────

model Generation {
  id             String           @id @default(cuid())
  workspaceId    String
  brandId        String
  productId      String?
  type           GenerationType
  status         GenerationStatus @default(PENDING)
  inputParams    Json
  outputContent  Json?
  liked          Boolean? // null = unrated, true = liked, false = disliked
  creditsUsed    Int              @default(0)
  model          String? // e.g. "gpt-4o"
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([workspaceId, type, createdAt(sort: Desc)])
  @@index([brandId, type, createdAt(sort: Desc)])
  @@index([workspaceId, liked])
}

// ─── Billing ────────────────────────────────────────────────────

model Subscription {
  id                   String              @id @default(cuid())
  workspaceId          String              @unique
  plan                 Plan?
  status               SubscriptionStatus  @default(TRIALING)

  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  stripePriceId        String?

  creditsPerCycle      Int                 @default(50) // trial default
  creditsRemaining     Int                 @default(50)
  cycleAnchor          DateTime?
  currentPeriodEnd     DateTime?

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id            String         @id @default(cuid())
  workspaceId   String
  kind          UsageEventKind
  creditsDelta  Int // negative for charges, positive for refills/refunds
  generationId  String?
  note          String?
  createdAt     DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
}

model ProcessedStripeEvent {
  eventId     String   @id
  type        String
  processedAt DateTime @default(now())
}
